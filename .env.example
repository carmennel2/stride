# Copy to .env and fill in real values. .env is gitignored.

# Signs session cookies and CSRF tokens. Generate one with:
#     python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-long-random-string

# Optional. Defaults to sqlite:///instance/stride.db when unset.
# DATABASE_URL=sqlite:///instance/stride.db


# ----------------------------------------------------------------------
# Google sign-in (optional)
# ----------------------------------------------------------------------
# Set both values to enable the "Sign in with Google" button on the
# login and signup pages. Leave unset to hide the button. Form-based
# signup/login keeps working either way.
#
# Register an OAuth 2.0 Client ID at:
#     https://console.cloud.google.com/apis/credentials
# Authorised redirect URIs:
#     http://127.0.0.1:5050/auth/oauth/google/callback   (development)
#     https://your-domain.example/auth/oauth/google/callback   (production)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
