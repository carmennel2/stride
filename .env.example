# Copy to .env and fill in real values. .env is gitignored.

# Signs session cookies and CSRF tokens. Generate one with:
#     python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-long-random-string

# Optional. Defaults to sqlite:///instance/stride.db when unset.
# DATABASE_URL=sqlite:///instance/stride.db


# ----------------------------------------------------------------------
# OAuth providers (optional)
# ----------------------------------------------------------------------
# Each block below is independent. Set both id and secret for a provider
# to enable its sign-in button on the login and signup pages; leave them
# unset to hide the button. Form-based signup/login keeps working in any
# combination.

# Google — register an OAuth 2.0 Client ID at:
#     https://console.cloud.google.com/apis/credentials
# Authorised redirect URI:
#     http://127.0.0.1:5050/auth/oauth/google/callback   (development)
#     https://your-domain.example/auth/oauth/google/callback   (production)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Microsoft — register an application at:
#     https://entra.microsoft.com/  (Microsoft Entra → App registrations)
# Pick the "Accounts in any organisational directory and personal Microsoft
# accounts" tenant option to match the "common" endpoint used by Stride.
# Redirect URI: same shape as Google, with provider=microsoft.
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# Facebook — create an app at:
#     https://developers.facebook.com/apps/
# Add the "Facebook Login" product, and under Settings -> Basic copy the
# App ID and App Secret. Add the redirect URI under Facebook Login ->
# Settings -> Valid OAuth Redirect URIs.
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
